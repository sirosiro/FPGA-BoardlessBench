/dts-v1/;
/ {
    /* 
     * i.MX8MP GPIO1
     * Base physical address: 0x30200000, Size: 0x1000
     */
    gpio1: gpio@30200000 {
        compatible = "fsl,imx8mp-gpio";
        reg = <0x30200000 0x1000>;
        label = "/dev/uio0";
        registers = 
            "DATA @ 0x00",
            "GDIR @ 0x04",
            "TRI  @ 0x08";
    };

    /* 
     * i.MX8MP UART1
     * Base physical address: 0x30860000, Size: 0x1000
     */
    uart1: serial@30860000 {
        compatible = "fsl,imx8mp-uart";
        reg = <0x30860000 0x1000>;
        label = "/dev/ttymxc0";
    };
};
