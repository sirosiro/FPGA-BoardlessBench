static int transfer_spi_msg_via_socket(int bus_id, int cs, struct spi_ioc_transfer *xfer) {
    char socket_path[128];
    snprintf(socket_path, sizeof(socket_path), "/tmp/fbb_spi_b%%d_c%%d", bus_id, cs);
    int sock_fd = socket(AF_UNIX, SOCK_STREAM, 0);
    if (sock_fd == -1) return -1;
    
    struct sockaddr_un addr;
    memset(&addr, 0, sizeof(addr));
    addr.sun_family = AF_UNIX;
    strncpy(addr.sun_path, socket_path, sizeof(addr.sun_path) - 1);
    
    int connected = 0;
    for (int retry = 0; retry < 15; retry++) {
        if (connect(sock_fd, (struct sockaddr*)&addr, sizeof(addr)) == 0) {
            connected = 1;
            break;
        }
        struct timespec ts = {0, 10000000}; // 10ms
        nanosleep(&ts, NULL);
    }
    
    if (!connected) {
        close(sock_fd);
        if (xfer->rx_buf) {
            memset((void*)(uintptr_t)xfer->rx_buf, 0, xfer->len);
        }
        return 0;
    }
    
    uint16_t msg_len = xfer->len;
    if (send(sock_fd, &msg_len, sizeof(msg_len), 0) < 0) {
        close(sock_fd);
        return -1;
    }
    
    uint8_t *tx_temp = NULL;
    const uint8_t *tx_ptr = (const uint8_t*)(uintptr_t)xfer->tx_buf;
    if (!tx_ptr) {
        tx_temp = calloc(1, msg_len);
        tx_ptr = tx_temp;
    }
    
    if (send(sock_fd, tx_ptr, msg_len, 0) < 0) {
        if (tx_temp) free(tx_temp);
        close(sock_fd);
        return -1;
    }
    if (tx_temp) free(tx_temp);
    
    uint8_t *rx_ptr = (uint8_t*)(uintptr_t)xfer->rx_buf;
    uint8_t *rx_temp = NULL;
    if (!rx_ptr) {
        rx_temp = malloc(msg_len);
        rx_ptr = rx_temp;
    }
    
    uint16_t received = 0;
    while (received < msg_len) {
        ssize_t r = recv(sock_fd, rx_ptr + received, msg_len - received, 0);
        if (r <= 0) {
            if (rx_temp) free(rx_temp);
            close(sock_fd);
            return -1;
        }
        received += r;
    }
    
    if (rx_temp) free(rx_temp);
    close(sock_fd);
    return 0;
}

static int transfer_i2c_msg_via_socket(int bus_id, struct i2c_msg *msg) {
    char socket_path[128];
    snprintf(socket_path, sizeof(socket_path), "/tmp/fbb_i2c_b%%d_a%%02x", bus_id, msg->addr);
    int sock_fd = socket(AF_UNIX, SOCK_STREAM, 0);
    if (sock_fd == -1) return -1;
    struct sockaddr_un addr;
    memset(&addr, 0, sizeof(addr));
    addr.sun_family = AF_UNIX;
    strncpy(addr.sun_path, socket_path, sizeof(addr.sun_path) - 1);
    if (connect(sock_fd, (struct sockaddr*)&addr, sizeof(addr)) == -1) {
        close(sock_fd);
        if (msg->flags & I2C_M_RD) memset(msg->buf, 0, msg->len);
        return 0;
    }
    uint16_t msg_addr = msg->addr;
    uint16_t msg_flags = msg->flags;
    uint16_t msg_len = msg->len;
    if (send(sock_fd, &msg_addr, sizeof(msg_addr), 0) < 0 ||
        send(sock_fd, &msg_flags, sizeof(msg_flags), 0) < 0 ||
        send(sock_fd, &msg_len, sizeof(msg_len), 0) < 0) {
        close(sock_fd);
        return -1;
    }
    if (!(msg->flags & I2C_M_RD)) {
        if (send(sock_fd, msg->buf, msg->len, 0) < 0) {
            close(sock_fd);
            return -1;
        }
    } else {
        uint16_t received = 0;
        while (received < msg->len) {
            ssize_t r = recv(sock_fd, msg->buf + received, msg->len - received, 0);
            if (r <= 0) {
                close(sock_fd);
                return -1;
            }
            received += r;
        }
    }
    close(sock_fd);
    return 0;
}

static const char *redirect_firmware_path(const char *pathname) {
    if (pathname != NULL && strncmp(pathname, "/lib/firmware/", 14) == 0) {
        static char redirected_path[1024];
        mkdir("/tmp", 0777);
        mkdir("/tmp/fbb", 0777);
        mkdir("/tmp/fbb/lib", 0777);
        mkdir("/tmp/fbb/lib/firmware", 0777);
        snprintf(redirected_path, sizeof(redirected_path), "/tmp/fbb/lib/firmware/%%s", pathname + 14);
        return redirected_path;
    }
    return pathname;
}

