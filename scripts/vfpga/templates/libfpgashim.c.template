static void __attribute__((constructor)) init_mcore_mapping(void) {
    char *fbb_mcore = getenv("FBB_MCORE");
    if (fbb_mcore && strcmp(fbb_mcore, "1") == 0) {
        if (!original_open) original_open = dlsym(RTLD_NEXT, "open");
        if (!original_mmap) original_mmap = dlsym(RTLD_NEXT, "mmap");
        for (int i = 0; i < (int)(sizeof(routes)/sizeof(routes[0])); i++) {
            int shm_fd = original_open(routes[i].shm_path, O_RDWR, 0666);
            if (shm_fd < 0) {
                fprintf(stderr, "[Shim M-Core] ERROR: Failed to open %%s (errno: %%d)\n", routes[i].shm_path, errno);
                continue;
            }
            void *addr = (void *)(uintptr_t)routes[i].base_addr;
            off_t offset = (off_t)(routes[i].base_addr - routes[0].base_addr);
            
            // Try safest first: MAP_FIXED_NOREPLACE (prevents overriding existing stack/heap mappings)
            void *mapped = original_mmap(addr, routes[i].size, PROT_READ | PROT_WRITE, MAP_SHARED | MAP_FIXED_NOREPLACE, shm_fd, offset);
            if (mapped == MAP_FAILED) {
                if (errno == EEXIST) {
                    fprintf(stderr, "[Shim M-Core] CRITICAL ERROR: Address collision at 0x%%lx (already mapped, EEXIST)\n", routes[i].base_addr);
                } else {
                    fprintf(stderr, "[Shim M-Core] ERROR: mmap MAP_FIXED_NOREPLACE failed for address 0x%%lx (errno: %%d)\n", routes[i].base_addr, errno);
                }
            } else if (mapped != addr) {
                // If MAP_FIXED_NOREPLACE is ignored by an older kernel, it maps to a different address.
                // We must unmap it and fall back to MAP_FIXED.
                munmap(mapped, routes[i].size);
                mapped = original_mmap(addr, routes[i].size, PROT_READ | PROT_WRITE, MAP_SHARED | MAP_FIXED, shm_fd, offset);
                if (mapped == MAP_FAILED) {
                    fprintf(stderr, "[Shim M-Core] ERROR: Fallback MAP_FIXED failed for address 0x%%lx (errno: %%d)\n", routes[i].base_addr, errno);
                } else {
                    fprintf(stdout, "[Shim M-Core] Successfully mapped 0x%%lx -> %%p with fallback MAP_FIXED\n", routes[i].base_addr, mapped);
                    fflush(stdout);
                }
            } else {
                fprintf(stdout, "[Shim M-Core] Successfully mapped 0x%%lx -> %%p with MAP_FIXED_NOREPLACE (size: %%ld, offset: %%ld)\n",
                        routes[i].base_addr, mapped, (long)routes[i].size, (long)offset);
                fflush(stdout);
            }
            close(shm_fd);
        }
    }
}

static void __attribute__((destructor)) cleanup_shim(void) {
    char *fbb_mcore = getenv("FBB_MCORE");
    if (!fbb_mcore || strcmp(fbb_mcore, "1") != 0) {
        unlink("/tmp/fbb/sys/class/remoteproc/remoteproc0/proxy_pid");
#ifdef FBB_WITH_OPENAMP
        if (rpmsg_running) {
            rpmsg_running = 0;
            pthread_join(rpmsg_thread, NULL);
            rpmsg_destroy_ept(&ept);
            rpmsg_deinit_vdev(&rvdev);
            if (app_socket_fd != -1) close(app_socket_fd);
            if (shim_socket_fd != -1) close(shim_socket_fd);
            if (signal_pipe[0] != -1) close(signal_pipe[0]);
            if (signal_pipe[1] != -1) close(signal_pipe[1]);
            if (rpmsg_shm_ptr) munmap(rpmsg_shm_ptr, SHM_SIZE);
            metal_finish();
        }
#endif
    }
}

static int (*original_mount)(const char *source, const char *target,
                             const char *filesystemtype, unsigned long mountflags,
                             const void *data) = NULL;
static int (*original_umount)(const char *target) = NULL;
static int (*original_umount2)(const char *target, int flags) = NULL;

int mount(const char *source, const char *target,
          const char *filesystemtype, unsigned long mountflags,
          const void *data) {
    if (!original_open) original_open = dlsym(RTLD_NEXT, "open");
    if (!original_mount) original_mount = dlsym(RTLD_NEXT, "mount");

    if (source != NULL && (strcmp(source, "/dev/mmcblk0") == 0 ||
                           strncmp(source, "/dev/mmcblk0p", 13) == 0)) {
        fprintf(stderr, "[Shim Debug] mount: redirecting virtual SD %%s to target %%s\n", source, target);
        fflush(stderr);

        const char *sd_dir = getenv("FBB_SD_DIR");
        char host_sd_path[1024];
        if (sd_dir != NULL) {
            snprintf(host_sd_path, sizeof(host_sd_path), "%%s", sd_dir);
        } else {
            FILE *f_scenario = fopen("/tmp/fbb_active_scenario", "r");
            int read_success = 0;
            if (f_scenario != NULL) {
                char active_dir[512];
                if (fgets(active_dir, sizeof(active_dir), f_scenario) != NULL) {
                    active_dir[strcspn(active_dir, "\r\n")] = 0;
                    if (strlen(active_dir) > 0) {
                        snprintf(host_sd_path, sizeof(host_sd_path), "%%s/sd_card", active_dir);
                        read_success = 1;
                    }
                }
                fclose(f_scenario);
            }
            if (!read_success) {
                snprintf(host_sd_path, sizeof(host_sd_path), "%%s/sandbox/sd_card", PROJECT_ROOT);
            }
        }

        // Ensure host-side SD directory exists
        mkdir(host_sd_path, 0777);

        // Ensure target directory exists and is cleared
        struct stat st;
        if (lstat(target, &st) == 0) {
            if (S_ISLNK(st.st_mode)) {
                unlink(target);
            } else if (S_ISDIR(st.st_mode)) {
                rmdir(target);
            }
        } else {
            // Parent directory creation
            char parent_dir[1024];
            snprintf(parent_dir, sizeof(parent_dir), "%%s", target);
            char *last_slash = strrchr(parent_dir, '/');
            if (last_slash != NULL && last_slash != parent_dir) {
                *last_slash = '\0';
                mkdir(parent_dir, 0777);
            }
        }

        // Create symlink: target -> host_sd_path
        if (symlink(host_sd_path, target) != 0) {
            perror("[Shim Error] symlink failed");
            return -1;
        }

        fprintf(stderr, "[Shim Debug] mount: successfully symlinked %%s -> %%s\n", target, host_sd_path);
        fflush(stderr);
        return 0;
    }

    return original_mount(source, target, filesystemtype, mountflags, data);
}

int umount(const char *target) {
    if (!original_umount) original_umount = dlsym(RTLD_NEXT, "umount");

    struct stat st;
    if (lstat(target, &st) == 0 && S_ISLNK(st.st_mode)) {
        fprintf(stderr, "[Shim Debug] umount: removing symlink redirection for %%s\n", target);
        fflush(stderr);
        if (unlink(target) == 0) {
            return 0;
        }
    }

    return original_umount(target);
}

int umount2(const char *target, int flags) {
    if (!original_umount2) original_umount2 = dlsym(RTLD_NEXT, "umount2");

    struct stat st;
    if (lstat(target, &st) == 0 && S_ISLNK(st.st_mode)) {
        fprintf(stderr, "[Shim Debug] umount2: removing symlink redirection for %%s\n", target);
        fflush(stderr);
        if (unlink(target) == 0) {
            return 0;
        }
    }

    return original_umount2(target, flags);
}
