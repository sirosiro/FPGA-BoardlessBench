static int find_route_by_path(const char *pathname, int *out_route_idx) {
    if (pathname == NULL) return 0;
    if (strcmp(pathname, "/dev/mem") == 0) { if (out_route_idx) *out_route_idx = -1; return 1; }
    for (int i = 0; i < (int)(sizeof(routes)/sizeof(routes[0])); i++) {
        if (strcmp(pathname, routes[i].path) == 0) {
            if (out_route_idx) *out_route_idx = i;
            return 1;
        }
    }
    return 0;
}

