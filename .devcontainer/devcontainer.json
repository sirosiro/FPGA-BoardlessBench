{
    "name": "FPGA-BoardlessBench Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "mshr-h.veriloghdl",
                "mshr-h.vsc-vcd-viewer",
                "rust-lang.rust-analyzer"
            ]
        }
    },
    "remoteUser": "root",
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined",
        "--shm-size=512m"
    ],
    "postCreateCommand": "npm --prefix dashboard install && npm --prefix dashboard/client install && npm --prefix dashboard/client run build",
    "forwardPorts": [8080]
}
